########################################
{%- if lsst.ticket %}
# https://rubinobs.atlassian.net/browse/{{ lsst.ticket }}
{%- endif %}
{%- if lsst.description %}
# {{ lsst.description }}
{%- endif %}
########################################
{%- if lsst.project %}
project: {{ lsst.project }}
{%- endif %}
{%- if lsst.campaign %}
campaign: {{ lsst.campaign }}
{%- endif %}
{%- if bps.operator %}
operator: {{ bps.operator }}
{%- endif %}
submitPath: {{ wms.working_directory }}/submit
uniqProcName: {{ bps.uniq_proc_name }}
{# BLANK LINE #}
########################################
# LSST SETUP
########################################
LSST_VERSION: {{ lsst.lsst_version }}
{# BLANK LINE #}
{%- if bps.variables|length > 0 %}
########################################
# BPS VARIABLES
########################################
{%- for key, value in bps.variables | items %}
{{ key }}: "{{ value }}"
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
########################################
# PIPELINE CONFIGURATION
########################################
pipelineYaml: {{ bps.pipeline_yaml }}
{%- if bps.include_files | length > 0 %}
includeConfigs:
{%- for config in bps.include_files %}
  - {{ config }}
{%- endfor %}
{%- endif %}
{# BLANK LINE #}
{%- if bps.environment %}
########################################
# SUBMISSION ENVIRONMENT VARIABLES
########################################
environment:
{%- for key, value in bps.environment|items %}
  {{ key }}: "{{ value }}"
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
########################################
# BPS PAYLOAD OPTIONS
########################################
{%- if bps.qgraph_file %}
qgraphFile: {{ bps.qgraph_file }}
{%- endif %}
payload:
{%- for key, value in bps.payload|items %}
  {{ key }}: "{{ value | trim }}"
{%- endfor %}
{%- if bps.extra_qgraph_options %}
extraQgraphOptions: {{ bps.extra_qgraph_options | join(" ")}}
{%- endif %}
{%- if bps.extra_run_quantum_options %}
extraRunQuantumOptions: {{ bps.extra_run_quantum_options | join(" ") }}
{%- endif %}
{%- if bps.extra_init_options %}
extraInitOptions: {{ bps.extra_init_options | join(" ") }}
{%- endif %}
{%- if bps.extra_update_qgraph_options %}
extraUpdateQgraphOptions: {{ bps.extra_update_qgraph_options | join(" ") }}
{%- endif %}
{# BLANK LINE #}
{%- if bps.clustering %}
########################################
# CLUSTERING CONFIGURATION
########################################
cluster:
  {{ bps.clustering | toyaml | indent(2) -}}
{# BLANK LINE #}
{%- endif%}
{%- if bps.literals %}
########################################
# AUXILIARY CONFIGURATION
########################################
{{ bps.literals | toyaml -}}
{# BLANK LINE #}
{%- endif%}
########################################
# SITE WMS CONFIGURATION
########################################
wmsServiceClass: {{ wms.service_class }}
computeSite: {{ site.facility }}
{%- if site.literals %}
{{ site.literals | toyaml -}}
{%- endif %}
{# BLANK LINE #}
########################################
# PROVISIONING CONFIGURATION
########################################
{%- if wms.batch_name %}
nodeset: {{ wms.batch_name }}
{%- endif %}
{%- if wms.auto_provision %}
provisionResources: {{ wms.auto_provision | string | lower }}
provisioning:
  provisioningNodeCount: {{ wms.provisioned_node_count }}
  provisioningMaxIdleTime: {{ wms.provisioned_idle_time }}
  provisioningMaxWallTime: {{ wms.provisioned_max_wall_time }}
  provisioningCheckInterval: {{ wms.provisioned_check_interval }}
  provisioningQueue: {{ site.provisioned_queue }}
  provisioningAccountingUser: {{ site.provisioned_account_group }}
  provisioningPlatform: "{{ site.provisioned_platform }}"
  provisioningExtraOptions: "{{ wms.provisioned_extra_arguments | join(' ') }}"
{# BLANK LINE #}
{%- endif %}
