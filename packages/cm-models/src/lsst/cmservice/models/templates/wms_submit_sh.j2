#!/usr/bin/env bash
set -e
{# BLANK LINE #}
{#- PHASE: HEADER =========================================================== #}
{%- if lsst.prepend %}
{%- for line in lsst.prepend %}
{{ line | shlex }}
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
{%- if lsst.launcher %}
{#- PHASE: LAUNCHER LSST SETUP ============================================== #}
{%- for line in lsst.launcher %}
{{ line | shlex }}
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
{%- if lsst.custom_lsst_setup %}
{%- for line in lsst.custom_lsst_setup %}
{{ line | shlex }}
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
{#- PHASE: WMS SETUP ======================================================== #}
{%- if wms.environment %}
{%- for key, value in wms.environment|items %}
export {{ key }}="{{ value }}"
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
{%- if wms.custom_setup %}
{%- for line in wms.custom_setup %}
{{ line | shlex }}
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
{#- PHASE: PAYLOAD COMMANDS ================================================= #}
{%- for command in lsst.command %}
{{ command | shlex }}
{# BLANK LINE #}
{%- endfor %}
{#- PHASE: POSTFLIGHT TRAILER =============================================== #}
{%- if lsst.append %}
{%- for line in lsst.append %}
{{ line | shlex }}
{%- endfor %}
{# BLANK LINE #}
{%- endif %}
